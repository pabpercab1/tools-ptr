# PTR upstream API used by the /api/ptr server proxy.
# Use an absolute URL. Trailing slash is optional.
VITE_UPSTREAM_API_URL=https://api.ptr.zanz2.dev

# Supabase project URL used by auth requests.
# Use an absolute URL. Trailing slash is optional.
VITE_SUPABASE_URL=https://vsajmskrbiyauigzyiof.supabase.co

# Optional override for Discord OAuth callback URL.
# Default behavior (when empty) uses window.location.origin.
VITE_DISCORD_REDIRECT_TO=https://toolsptr.qzz.io

# Toggle Discord login visibility/usage in the sign-in modal.
# Accepted true values: true, 1, yes. Default is disabled.
VITE_DISCORD_LOGIN_ENABLED=false